# RunPod SSH connection (required)
RUNPOD_SSH_HOST=
RUNPOD_SSH_PORT=

# Experiment configuration (optional, with defaults)
MORPHOGPT_NUM_REPS=30
MORPHOGPT_NUM_STEPS=200
MORPHOGPT_EXPERIMENTS=all    # all | experiment1 | experiment2 | ... | experiment6

# Timezone for remote logs (POSIX Etc/GMT-2 = UTC+2, inverted sign)
RUNPOD_TZ=Etc/GMT-2
